@*
    WPF/WinForms/MAUI의 DreamineDataGrid와 동일한 개념의 Blazor용 데이터 그리드(읽기 표시용).
    HeaderContent 에 <th>, RowContent(item) 에 <td> 를 넣으면 된다.
    행 클릭으로 선택(@bind-SelectedItem), 다시 클릭하면 해제.
    @typeparam TItem 행 데이터 타입.
*@
@typeparam TItem

<div class="dreamine-datagrid-wrap">
    <table class="dreamine-datagrid">
        @if (HeaderContent is not null)
        {
            <thead>
                <tr>@HeaderContent</tr>
            </thead>
        }
        <tbody>
            @foreach (var item in Items)
            {
                <tr class="@(EqualityComparer<TItem>.Default.Equals(item, SelectedItem) ? "is-selected" : "")"
                    @onclick="() => ToggleSelectAsync(item)">
                    @RowContent?.Invoke(item)
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    /// <summary><para>[KO] 표에 표시할 데이터 항목을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the data items displayed in the grid.</para></summary>
    [Parameter] public IEnumerable<TItem> Items { get; set; } = Array.Empty<TItem>();
    /// <summary><para>[KO] 현재 선택한 데이터 항목을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the currently selected data item.</para></summary>
    [Parameter] public TItem? SelectedItem { get; set; }
    /// <summary><para>[KO] 선택 항목이 변경될 때 호출할 콜백을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the callback invoked when the selected item changes.</para></summary>
    [Parameter] public EventCallback<TItem?> SelectedItemChanged { get; set; }
    /// <summary><para>[KO] 표 머리글에 렌더링할 콘텐츠를 가져오거나 설정합니다.</para><para>[EN] Gets or sets the content rendered in the grid header.</para></summary>
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    /// <summary><para>[KO] 각 데이터 행을 렌더링할 템플릿을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the template used to render each data row.</para></summary>
    [Parameter] public RenderFragment<TItem>? RowContent { get; set; }

    /// <summary><para>[KO] 선택된 행을 다시 클릭하여 선택을 해제할 수 있는지 여부를 가져오거나 설정합니다.</para><para>[EN] Gets or sets whether clicking a selected row again can clear the selection.</para></summary>
    [Parameter] public bool AllowDeselect { get; set; } = true;

    /// <summary><para>[KO] 지정한 항목의 선택 상태를 전환하고 변경 콜백을 호출합니다.</para><para>[EN] Toggles selection of the specified item and invokes the change callback.</para></summary>
    /// <param name="item"><para>[KO] 선택 상태를 전환할 데이터 항목입니다.</para><para>[EN] The data item whose selection state is toggled.</para></param>
    /// <returns><para>[KO] 선택 변경 전달을 나타내는 작업입니다.</para><para>[EN] A task representing propagation of the selection change.</para></returns>
    private async Task ToggleSelectAsync(TItem item)
    {
        var isSame = EqualityComparer<TItem>.Default.Equals(item, SelectedItem);
        SelectedItem = (AllowDeselect && isSame) ? default : item;
        await SelectedItemChanged.InvokeAsync(SelectedItem);
    }
}
