@*
    Blazor version of WPF Dreamine.UI.Wpf.Equipment.DreamineVirtualKeyboard.
    Browsers cannot use OS hooks or IME injection here, so JS interop edits the
    most recently focused text input directly.
*@

@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsVisible)
{
    <div class="dreamine-vk" @onkeyup="OnHostKeyUp" tabindex="-1">
        @* Row 0: Esc/numbers/=/Backspace *@
        <div class="dreamine-vk-row">
            @foreach (var k in Row0) {
                <button type="button" class="dreamine-vk-key @KeyClass(k)"
                        tabindex="-1"
                        @onmousedown:preventDefault="true"
                        @onpointerdown:preventDefault="true"
                        @onclick="() => OnKeyClick(k)">@KeyLabel(k)</button>
            }
        </div>

        @* Row 1: Tab/qwerty/[]\ (same WPF layout: Backspace is only on row 0) *@
        <div class="dreamine-vk-row">
            <button type="button" class="dreamine-vk-key dreamine-vk-key-md"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick='() => Insert("    ")'>Tab</button>
            @foreach (var k in Row1) {
                <button type="button" class="dreamine-vk-key"
                        tabindex="-1"
                        @onmousedown:preventDefault="true"
                        @onpointerdown:preventDefault="true"
                        @onclick="() => OnKeyClick(k)">@KeyLabel(k)</button>
            }
        </div>

        @* Row 2: CapsLock/asdf/Enter *@
        <div class="dreamine-vk-row">
            <button type="button" class="dreamine-vk-key dreamine-vk-key-lg @(IsPressedCapsLock ? "is-active" : "")"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="ToggleCapsLock">
                <span class="dreamine-vk-label-full">Caps Lock</span>
                <span class="dreamine-vk-label-short">Caps</span>
            </button>
            @foreach (var k in Row2) {
                <button type="button" class="dreamine-vk-key"
                        tabindex="-1"
                        @onmousedown:preventDefault="true"
                        @onpointerdown:preventDefault="true"
                        @onclick="() => OnKeyClick(k)">@KeyLabel(k)</button>
            }
            <button type="button" class="dreamine-vk-key dreamine-vk-key-lg"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="OnEnterClicked">
                <span class="dreamine-vk-label-full">Enter</span>
                <span class="dreamine-vk-label-short">↵</span>
            </button>
        </div>

        @* Row 3: Shift/zxcv/arrows *@
        <div class="dreamine-vk-row">
            <button type="button" class="dreamine-vk-key dreamine-vk-key-lg @(IsPressedShift ? "is-active" : "")"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="ToggleShift">
                <span class="dreamine-vk-label-full">Shift</span>
                <span class="dreamine-vk-label-short">⇧</span>
            </button>
            @foreach (var k in Row3) {
                <button type="button" class="dreamine-vk-key"
                        tabindex="-1"
                        @onmousedown:preventDefault="true"
                        @onpointerdown:preventDefault="true"
                        @onclick="() => OnKeyClick(k)">@KeyLabel(k)</button>
            }
            <button type="button" class="dreamine-vk-key"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="MoveCaretLeft">◀</button>
            <button type="button" class="dreamine-vk-key"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="MoveCaretRight">▶</button>
        </div>

        @* Row 4: Ctrl/Space/IME/language *@
        <div class="dreamine-vk-row">
            <button type="button" class="dreamine-vk-key dreamine-vk-key-md"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true">Ctrl</button>
            <button type="button" class="dreamine-vk-key dreamine-vk-key-space"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick='() => Insert(" ")'>
                <span class="dreamine-vk-label-full">Space</span>
                <span class="dreamine-vk-label-short">␣</span>
            </button>
            <button type="button" class="dreamine-vk-key dreamine-vk-key-md"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="ToggleImeMode">@ImeButtonLabel</button>
            <button type="button" class="dreamine-vk-key dreamine-vk-key-md"
                    tabindex="-1"
                    @onmousedown:preventDefault="true"
                    @onpointerdown:preventDefault="true"
                    @onclick="ToggleLanguage">@LangButtonLabel</button>
        </div>
    </div>
}

@code {
    /// <summary><para>[KO] 가상 키보드가 표시되는지 여부를 가져오거나 설정합니다.</para><para>[EN] Gets or sets whether the virtual keyboard is visible.</para></summary>
    [Parameter] public bool IsVisible { get; set; }
    /// <summary><para>[KO] JavaScript 편집 대상을 사용할 수 없을 때 편집할 대체 입력 값을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the fallback input value edited when no JavaScript target is available.</para></summary>
    [Parameter] public string Value { get; set; } = string.Empty;
    /// <summary><para>[KO] 대체 입력 값이 변경될 때 호출할 콜백을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the callback invoked when the fallback input value changes.</para></summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    /// <summary><para>[KO] Enter 키를 누를 때 호출할 콜백을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the callback invoked when the Enter key is pressed.</para></summary>
    [Parameter] public EventCallback OnEnter { get; set; }

    // State
    private bool VirtualShift;
    private bool PhysicalShift;
    private bool VirtualCapsLock;
    private bool PhysicalCapsLock;
    private bool CurrentLangKorean;   // false = en_US, true = ko_KR
    private bool ImeMode;             // false = jamo/English input mode, true = Hangul composition mode
    private readonly HangulComposer _composer = new();
    /// <summary><para>[KO] 가상 또는 물리 Shift 키가 눌린 상태인지 여부를 가져옵니다.</para><para>[EN] Gets whether either the virtual or physical Shift key is pressed.</para></summary>
    private bool IsPressedShift => VirtualShift || PhysicalShift;
    /// <summary><para>[KO] 가상 또는 물리 Caps Lock이 활성 상태인지 여부를 가져옵니다.</para><para>[EN] Gets whether either virtual or physical Caps Lock is active.</para></summary>
    private bool IsPressedCapsLock => VirtualCapsLock || PhysicalCapsLock;

    // JS helper module reference. Falls back when unavailable.
    private IJSObjectReference? _js;
    private DotNetObjectReference<DreamineVirtualKeyboard>? _dotNetRef;

    /// <summary><para>[KO] 현재 언어 선택 버튼에 표시할 레이블을 가져옵니다.</para><para>[EN] Gets the label displayed on the current language-selection button.</para></summary>
    private string LangButtonLabel => CurrentLangKorean ? "KR" : "US";
    /// <summary><para>[KO] 현재 IME 모드 버튼에 표시할 레이블을 가져옵니다.</para><para>[EN] Gets the label displayed on the current IME-mode button.</para></summary>
    private string ImeButtonLabel => CurrentLangKorean ? (ImeMode ? "가" : "abc") : "abc";

    /// <summary><para>[KO] 첫 렌더링 후 JavaScript 키보드 모듈을 불러오고 물리 키 상태 구독을 시작합니다.</para><para>[EN] Loads the JavaScript keyboard module and begins physical-key-state subscription after the first render.</para></summary>
    /// <param name="firstRender"><para>[KO] 컴포넌트의 첫 렌더링이면 <see langword="true"/>입니다.</para><para>[EN] <see langword="true"/> when this is the component's first render.</para></param>
    /// <returns><para>[KO] 렌더링 후 초기화 작업을 나타내는 작업입니다.</para><para>[EN] A task representing post-render initialization.</para></returns>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _js = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/Dreamine.UI.Blazor/dreamine-vk.js");
                _dotNetRef = DotNetObjectReference.Create(this);
                await _js.InvokeVoidAsync("subscribeKeyboardState", _dotNetRef);
            }
            catch
            {
                // Fall back when static files are unavailable, such as tests or prerendering.
                _js = null;
            }
        }
    }

    /// <summary><para>[KO] JavaScript 키 상태 구독, 모듈 참조 및 .NET 객체 참조를 비동기로 해제합니다.</para><para>[EN] Asynchronously releases the JavaScript key-state subscription, module reference, and .NET object reference.</para></summary>
    /// <returns><para>[KO] 비동기 해제 작업입니다.</para><para>[EN] A value task representing asynchronous disposal.</para></returns>
    public async ValueTask DisposeAsync()
    {
        if (_js is not null)
        {
            try
            {
                if (_dotNetRef is not null)
                    await _js.InvokeVoidAsync("unsubscribeKeyboardState", _dotNetRef);
            }
            catch { /* ignore */ }

            try { await _js.DisposeAsync(); } catch { /* ignore */ }
        }

        _dotNetRef?.Dispose();
    }

    // Key mapping. Conceptually matches the WPF Key.cs arrays.
    /// <summary><para>[KO] 키의 기본, Shift, 한국어 및 표시 레이블 매핑을 나타냅니다.</para><para>[EN] Represents default, shifted, Korean, and display-label mappings for a key.</para></summary>
    /// <param name="Normal"><para>[KO] 기본 입력 값입니다.</para><para>[EN] The normal input value.</para></param>
    /// <param name="Shifted"><para>[KO] Shift 상태의 입력 값입니다.</para><para>[EN] The shifted input value.</para></param>
    /// <param name="Korean"><para>[KO] 한국어 입력 값입니다.</para><para>[EN] The Korean input value.</para></param>
    /// <param name="KoreanShifted"><para>[KO] Shift 상태의 한국어 입력 값입니다.</para><para>[EN] The shifted Korean input value.</para></param>
    /// <param name="Label"><para>[KO] 입력 값 대신 표시할 선택적 레이블입니다.</para><para>[EN] An optional label displayed instead of the input value.</para></param>
    private sealed record KeyMap(string Normal, string Shifted = "", string Korean = "", string KoreanShifted = "", string Label = "");

    private static readonly KeyMap[] Row0 =
    {
        new("Esc", Label: "Esc"),
        new("`", "~"),
        new("1", "!"), new("2", "@"), new("3", "#"), new("4", "$"), new("5", "%"),
        new("6", "^"), new("7", "&"), new("8", "*"), new("9", "("), new("0", ")"),
        new("-", "_"), new("=", "+"),
        new("Backspace", Label: "⌫"),
    };

    private static readonly KeyMap[] Row1 =
    {
        new("q", "Q", "ㅂ", "ㅃ"), new("w", "W", "ㅈ", "ㅉ"), new("e", "E", "ㄷ", "ㄸ"),
        new("r", "R", "ㄱ", "ㄲ"), new("t", "T", "ㅅ", "ㅆ"), new("y", "Y", "ㅛ"),
        new("u", "U", "ㅕ"), new("i", "I", "ㅑ"), new("o", "O", "ㅐ", "ㅒ"),
        new("p", "P", "ㅔ", "ㅖ"), new("[", "{"), new("]", "}"), new("\\", "|"),
    };

    private static readonly KeyMap[] Row2 =
    {
        new("a", "A", "ㅁ"), new("s", "S", "ㄴ"), new("d", "D", "ㅇ"),
        new("f", "F", "ㄹ"), new("g", "G", "ㅎ"), new("h", "H", "ㅗ"),
        new("j", "J", "ㅓ"), new("k", "K", "ㅏ"), new("l", "L", "ㅣ"),
        new(";", ":"), new("'", "\""),
    };

    private static readonly KeyMap[] Row3 =
    {
        new("z", "Z", "ㅋ"), new("x", "X", "ㅌ"), new("c", "C", "ㅊ"),
        new("v", "V", "ㅍ"), new("b", "B", "ㅠ"), new("n", "N", "ㅜ"),
        new("m", "M", "ㅡ"),
        new(",", "<"), new(".", ">"), new("/", "?"),
    };

    /// <summary><para>[KO] 현재 언어와 수정 키 상태에 맞는 키 표시 문자열을 계산합니다.</para><para>[EN] Computes the key display string for the current language and modifier state.</para></summary>
    /// <param name="k"><para>[KO] 레이블을 계산할 키 매핑입니다.</para><para>[EN] The key mapping whose label is calculated.</para></param>
    /// <returns><para>[KO] 화면에 표시할 키 레이블입니다.</para><para>[EN] The key label to display.</para></returns>
    private string KeyLabel(KeyMap k)
    {
        if (!string.IsNullOrEmpty(k.Label))
            return k.Label;

        var isLetter = k.Normal.Length == 1 && char.IsLetter(k.Normal, 0);
        var korActive = CurrentLangKorean && ImeMode;

        if (korActive && !string.IsNullOrEmpty(k.Korean))
        {
            return IsPressedShift && !string.IsNullOrEmpty(k.KoreanShifted)
                ? k.KoreanShifted
                : k.Korean;
        }

        var showUpper = isLetter && (IsPressedShift ^ IsPressedCapsLock);
        var displayShifted = IsPressedShift && !string.IsNullOrEmpty(k.Shifted);

        if (displayShifted) return k.Shifted;
        return showUpper ? k.Normal.ToUpper() : k.Normal;
    }

    /// <summary><para>[KO] 특수 키의 너비에 맞는 CSS 클래스를 반환합니다.</para><para>[EN] Returns the CSS class appropriate for the width of a special key.</para></summary>
    /// <param name="k"><para>[KO] CSS 클래스를 결정할 키 매핑입니다.</para><para>[EN] The key mapping whose CSS class is determined.</para></param>
    /// <returns><para>[KO] 키에 추가할 CSS 클래스이거나 기본 너비이면 빈 문자열입니다.</para><para>[EN] The CSS class to add to the key, or an empty string for the default width.</para></returns>
    private string KeyClass(KeyMap k)
    {
        if (k.Label == "Esc") return "dreamine-vk-key-sm";
        if (k.Label == "⌫") return "dreamine-vk-key-md";
        return string.Empty;
    }

    /// <summary><para>[KO] 가상 키 클릭을 특수 키 처리 또는 문자 삽입으로 전달합니다.</para><para>[EN] Routes a virtual-key click to special-key handling or character insertion.</para></summary>
    /// <param name="k"><para>[KO] 클릭된 키의 매핑입니다.</para><para>[EN] The mapping of the clicked key.</para></param>
    /// <returns><para>[KO] 키 처리 작업입니다.</para><para>[EN] A task representing key processing.</para></returns>
    private async Task OnKeyClick(KeyMap k)
    {
        if (k.Label == "Esc")
        {
            _composer.Reset();
            return;
        }
        if (k.Label == "⌫")
        {
            await Backspace();
            return;
        }

        var text = KeyLabel(k);
        await Insert(text);
    }

    // JS interop result context. JS passes camelCase values, so map them explicitly.
    /// <summary><para>[KO] JavaScript 입력 요소에서 읽은 값과 선택 범위를 나타냅니다.</para><para>[EN] Represents a value and selection range read from a JavaScript input element.</para></summary>
    private sealed class VkContext
    {
        /// <summary><para>[KO] 입력 요소의 전체 값을 가져오거나 설정합니다.</para><para>[EN] Gets or sets the complete input-element value.</para></summary>
        [System.Text.Json.Serialization.JsonPropertyName("value")]
        public string Value { get; set; } = string.Empty;

        /// <summary><para>[KO] 선택 범위의 시작 인덱스를 가져오거나 설정합니다.</para><para>[EN] Gets or sets the starting index of the selection range.</para></summary>
        [System.Text.Json.Serialization.JsonPropertyName("start")]
        public int Start { get; set; }

        /// <summary><para>[KO] 선택 범위의 끝 인덱스를 가져오거나 설정합니다.</para><para>[EN] Gets or sets the ending index of the selection range.</para></summary>
        [System.Text.Json.Serialization.JsonPropertyName("end")]
        public int End { get; set; }
    }

    /// <summary><para>[KO] 현재 포커스된 JavaScript 입력 요소의 값과 선택 범위를 가져오려고 시도합니다.</para><para>[EN] Attempts to retrieve the value and selection range of the currently focused JavaScript input element.</para></summary>
    /// <returns><para>[KO] 입력 컨텍스트이거나 모듈을 사용할 수 없거나 호출에 실패하면 <see langword="null"/>입니다.</para><para>[EN] The input context, or <see langword="null"/> when the module is unavailable or the call fails.</para></returns>
    private async Task<VkContext?> GetContextAsync()
    {
        if (_js is null) return null;
        try
        {
            // JS returns an object or null. Use a non-nullable type here and let the
            // catch path handle environments where nullable JSInterop casting fails.
            return await _js.InvokeAsync<VkContext>("getContext");
        }
        catch { return null; }
    }

    /// <summary><para>[KO] JavaScript 입력 요소의 캐럿 앞 문자를 교체하고 새 텍스트를 삽입하려고 시도합니다.</para><para>[EN] Attempts to replace characters before the caret and insert new text in the JavaScript input element.</para></summary>
    /// <param name="replaceCount"><para>[KO] 캐럿 앞에서 교체할 문자 수입니다.</para><para>[EN] The number of characters to replace before the caret.</para></param>
    /// <param name="insertText"><para>[KO] 교체 위치에 삽입할 텍스트입니다.</para><para>[EN] The text to insert at the replacement position.</para></param>
    /// <returns><para>[KO] 편집에 성공하면 <see langword="true"/>, 그렇지 않으면 <see langword="false"/>입니다.</para><para>[EN] <see langword="true"/> if the edit succeeds; otherwise, <see langword="false"/>.</para></returns>
    private async Task<bool> ApplyEditAsync(int replaceCount, string insertText)
    {
        if (_js is null) return false;
        try
        {
            // JS returns -1 on failure or the new caret index on success.
            var result = await _js.InvokeAsync<int>("applyEdit", replaceCount, insertText);
            return result >= 0;
        }
        catch { return false; }
    }

    /// <summary><para>[KO] 현재 언어 및 IME 상태에 따라 텍스트를 포커스 입력 요소 또는 대체 값에 삽입합니다.</para><para>[EN] Inserts text into the focused input element or fallback value according to the current language and IME state.</para></summary>
    /// <param name="text"><para>[KO] 삽입할 텍스트입니다.</para><para>[EN] The text to insert.</para></param>
    /// <returns><para>[KO] 삽입 작업입니다.</para><para>[EN] A task representing the insertion operation.</para></returns>
    private async Task Insert(string text)
    {
        if (string.IsNullOrEmpty(text)) return;

        var ctx = await GetContextAsync();

        // Use HangulComposer when the IME mode is composing Korean jamo.
        if (CurrentLangKorean && ImeMode && HangulComposer.IsComposableJamo(text))
        {
            if (ctx is not null)
            {
                var before = ctx.Value[..Math.Clamp(ctx.Start, 0, ctx.Value.Length)];
                var edit = _composer.Input(text, before);
                if (await ApplyEditAsync(edit.ReplaceCount, edit.Text))
                    return;
            }

            // Fallback: edit the local Value.
            await FallbackHangulInsertAsync(text);
            return;
        }

        // Regular characters.
        _composer.Reset();
        if (ctx is not null)
        {
            if (await ApplyEditAsync(0, text))
                return;
        }

        await FallbackAppendAsync(text);
    }

    /// <summary><para>[KO] 포커스 입력 요소 또는 대체 값에서 캐럿 앞 문자를 삭제합니다.</para><para>[EN] Deletes the character before the caret from the focused input element or fallback value.</para></summary>
    /// <returns><para>[KO] 삭제 작업입니다.</para><para>[EN] A task representing the deletion operation.</para></returns>
    private async Task Backspace()
    {
        _composer.Reset();
        if (_js is not null)
        {
            try
            {
                // JS returns the new caret index on success or -1 when no target exists.
                var result = await _js.InvokeAsync<int>("backspace");
                if (result >= 0) return;
            }
            catch { }
        }

        // Fallback: delete the last character from Value.
        if (string.IsNullOrEmpty(Value)) return;
        Value = Value[..^1];
        await ValueChanged.InvokeAsync(Value);
    }

    /// <summary><para>[KO] 한글 조합 상태를 초기화하고 JavaScript 입력 요소의 캐럿을 왼쪽으로 이동합니다.</para><para>[EN] Resets Hangul composition and moves the caret of the JavaScript input element to the left.</para></summary>
    /// <returns><para>[KO] 캐럿 이동 작업입니다.</para><para>[EN] A task representing the caret movement.</para></returns>
    private async Task MoveCaretLeft()
    {
        _composer.Reset();
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("moveCaret", -1); } catch { }
        }
    }

    /// <summary><para>[KO] 한글 조합 상태를 초기화하고 JavaScript 입력 요소의 캐럿을 오른쪽으로 이동합니다.</para><para>[EN] Resets Hangul composition and moves the caret of the JavaScript input element to the right.</para></summary>
    /// <returns><para>[KO] 캐럿 이동 작업입니다.</para><para>[EN] A task representing the caret movement.</para></returns>
    private async Task MoveCaretRight()
    {
        _composer.Reset();
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("moveCaret", 1); } catch { }
        }
    }

    // Local Value fallback editing.
    /// <summary><para>[KO] JavaScript 편집을 사용할 수 없을 때 로컬 값의 끝에서 한글 자모를 조합합니다.</para><para>[EN] Composes Hangul jamo at the end of the local value when JavaScript editing is unavailable.</para></summary>
    /// <param name="text"><para>[KO] 조합할 한글 자모입니다.</para><para>[EN] The Hangul jamo to compose.</para></param>
    /// <returns><para>[KO] 로컬 값과 변경 콜백 갱신 작업입니다.</para><para>[EN] A task representing the local-value and change-callback update.</para></returns>
    private async Task FallbackHangulInsertAsync(string text)
    {
        var before = Value ?? string.Empty;
        var edit = _composer.Input(text, before);
        var newBefore = edit.ReplaceCount > 0 && before.Length >= edit.ReplaceCount
            ? before[..^edit.ReplaceCount] + edit.Text
            : before + edit.Text;
        Value = newBefore;
        await ValueChanged.InvokeAsync(Value);
    }

    /// <summary><para>[KO] JavaScript 편집을 사용할 수 없을 때 텍스트를 로컬 값 끝에 추가합니다.</para><para>[EN] Appends text to the local value when JavaScript editing is unavailable.</para></summary>
    /// <param name="text"><para>[KO] 추가할 텍스트입니다.</para><para>[EN] The text to append.</para></param>
    /// <returns><para>[KO] 로컬 값과 변경 콜백 갱신 작업입니다.</para><para>[EN] A task representing the local-value and change-callback update.</para></returns>
    private async Task FallbackAppendAsync(string text)
    {
        Value = (Value ?? string.Empty) + text;
        await ValueChanged.InvokeAsync(Value);
    }

    /// <summary><para>[KO] 가상 Shift 키 상태를 전환합니다.</para><para>[EN] Toggles the virtual Shift-key state.</para></summary>
    private void ToggleShift() => VirtualShift = !VirtualShift;

    /// <summary><para>[KO] 가상 Caps Lock 상태를 전환하고 진행 중인 한글 조합을 초기화합니다.</para><para>[EN] Toggles virtual Caps Lock and resets any in-progress Hangul composition.</para></summary>
    private void ToggleCapsLock()
    {
        VirtualCapsLock = !VirtualCapsLock;
        _composer.Reset();
    }

    // IME toggle: switches abc <-> Hangul only while the Korean layout is active.
    /// <summary><para>[KO] 한국어 레이아웃에서 영문 자모 입력과 한글 조합 모드를 전환합니다.</para><para>[EN] Toggles between raw alphabet/jamo input and Hangul composition in the Korean layout.</para></summary>
    private void ToggleImeMode()
    {
        if (!CurrentLangKorean) return;
        ImeMode = !ImeMode;
        _composer.Reset();
    }

    // Language toggle: EN <-> KR. This only affects labels and composition mode.
    /// <summary><para>[KO] 영어와 한국어 레이아웃을 전환하고 한국어 선택 시 조합 모드를 활성화합니다.</para><para>[EN] Toggles between English and Korean layouts and enables composition when Korean is selected.</para></summary>
    private void ToggleLanguage()
    {
        CurrentLangKorean = !CurrentLangKorean;
        ImeMode = CurrentLangKorean;      // Korean layout starts in Hangul input mode.
        _composer.Reset();
    }

    /// <summary><para>[KO] 한글 조합을 초기화하고 구성된 Enter 콜백을 호출합니다.</para><para>[EN] Resets Hangul composition and invokes the configured Enter callback.</para></summary>
    /// <returns><para>[KO] Enter 콜백 호출을 나타내는 작업입니다.</para><para>[EN] A task representing the Enter callback invocation.</para></returns>
    private async Task OnEnterClicked()
    {
        _composer.Reset();
        await OnEnter.InvokeAsync();
    }

    // Sync the visual CapsLock state when the physical keyboard exposes it.
    /// <summary><para>[KO] 물리 키보드 이벤트에서 Caps Lock 상태를 읽어 시각적 상태와 동기화합니다.</para><para>[EN] Reads Caps Lock state from a physical-keyboard event and synchronizes the visual state.</para></summary>
    /// <param name="e"><para>[KO] 브라우저 키보드 이벤트 인수입니다.</para><para>[EN] The browser keyboard event arguments.</para></param>
    private void OnHostKeyUp(KeyboardEventArgs e)
    {
        try
        {
            var caps = (bool)(typeof(KeyboardEventArgs).GetProperty("CapsLockOn")?.GetValue(e) ?? false);
            if (caps != PhysicalCapsLock)
                PhysicalCapsLock = caps;
        }
        catch { }
    }

    /// <summary><para>[KO] JavaScript에서 전달된 물리 Shift 및 Caps Lock 상태를 적용하고 다시 렌더링합니다.</para><para>[EN] Applies physical Shift and Caps Lock state received from JavaScript and requests a rerender.</para></summary>
    /// <param name="shift"><para>[KO] 물리 Shift 키가 눌렸으면 <see langword="true"/>입니다.</para><para>[EN] <see langword="true"/> if the physical Shift key is pressed.</para></param>
    /// <param name="capsLock"><para>[KO] 물리 Caps Lock이 활성화됐으면 <see langword="true"/>입니다.</para><para>[EN] <see langword="true"/> if physical Caps Lock is active.</para></param>
    /// <returns><para>[KO] 상태 변경 렌더링 작업입니다.</para><para>[EN] A task representing rendering after the state change.</para></returns>
    [Microsoft.JSInterop.JSInvokable]
    public Task DreamineVkKeyboardStateChanged(bool shift, bool capsLock)
    {
        PhysicalShift = shift;
        PhysicalCapsLock = capsLock;
        return InvokeAsync(StateHasChanged);
    }
}
